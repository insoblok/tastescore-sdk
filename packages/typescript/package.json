{
  "name": "@insoblok/tastescore-sdk",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript SDK for the TasteScore V2 crypto wallet reputation API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tastescore",
    "crypto",
    "wallet",
    "reputation",
    "scoring",
    "web3",
    "defi",
    "blockchain",
    "trust",
    "insoblokai"
  ],
  "author": "InSoBlok <dev@insoblokai.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/insoblok/tastescore-sdk.git",
    "directory": "packages/typescript"
  },
  "homepage": "https://github.com/insoblok/tastescore-sdk/tree/main/packages/typescript",
  "bugs": {
    "url": "https://github.com/insoblok/tastescore-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
